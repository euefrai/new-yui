## Copie este arquivo para ".env" e preencha os valores.
##
## Windows (PowerShell):
##   Copy-Item .env.example .env
##
## Linux/macOS:
##   cp .env.example .env

# Obrigatório para respostas via OpenAI (opcional se você não for usar conversa por IA)
OPENAI_API_KEY=coloque_sua_chave_aqui

# Opcional: modelo padrão (se não informado, o código usa um default)
# OPENAI_MODEL=gpt-4o-mini

# Supabase (login e chats por usuário)
# SUPABASE_URL=https://seu-projeto.supabase.co
# SUPABASE_KEY=chave_service_role (só servidor; nunca expor no frontend)
# SUPABASE_PUBLISHABLE_KEY=chave_publica_ou_anon (para o navegador: login/Auth)
# SUPABASE_JWT_SECRET=opcional_para_verificar_token_no_backend

# PostgreSQL direto (opcional; senha com @ use %40 na URL)
# DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres
